{
  "name": "@ledgerpilot/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first AI personal finance desktop app for macOS.",
  "author": "dios-me-bendigaa",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=dist-electron/main.js --external:electron --external:better-sqlite3 && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "build": "npm run build:electron && vite build",
    "dev": "vite",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "package:mac": "npm run build && electron-builder --mac dmg --$TARGET_ARCH",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@ledgerpilot/core": "1.0.0",
    "@ledgerpilot/import-engine": "1.0.0",
    "@ledgerpilot/normalization-engine": "1.0.0",
    "@ledgerpilot/ui": "1.0.0",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.9",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.ledgerpilot.desktop",
    "productName": "LedgerPilot",
    "electronVersion": "31.7.7",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "build/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "mac": {
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ]
    }
  }
}
